{
  "expo": {
    "name": "Narae Voyage",
    "slug": "narae-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.naraevoyage.app",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#020617"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.naraevoyage.app",
      "buildNumber": "10",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "Narae Voyage",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.naraevoyage.app",
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-sharing",
      [
        "expo-calendar",
        {
          "calendarPermission": "Narae Voyage a besoin d'accéder à votre calendrier pour y ajouter vos activités de voyage."
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e2c0abee-87a1-41dc-8e38-207943506430"
      }
    }
  }
}
